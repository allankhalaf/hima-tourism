{
  "name": "hima-tourism",
  "version": "1.0.0",
  "description": "موقع Hima Tourism لتنظيم الرحلات السياحية والتخييم - مشروع تخرج أكاديمية حسوب",
  "main": "src/js/index.js",
  "scripts": {
    "build": "webpack --mode=production",
    "deploy": "npm run build && gh-pages -d dist",
