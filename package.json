    "start": "npm run build && live-server dist --open=/"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "gh-pages": "^6.1.1",
    "html-webpack-plugin": "^5.5.3",
    "live-server": "^1.2.2",
    "mini-css-extract-plugin": "^2.7.6",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "bootstrap": "^5.3.2",
    "bootstrap-icons": "^1.11.1",
    "jquery": "^3.7.1"
  }
}
